# Copy this file to .env and fill in real values.
# .env is gitignored and must never be committed.

SERVER_PORT=8080

DB_URL=jdbc:postgresql://localhost:5432/hospital_management
DB_USERNAME=postgres
DB_PASSWORD=change_me

# Optional: explicit basic auth credentials for local development.
# If unset, Spring Security may generate a random password at startup.
SPRING_SECURITY_USER_NAME=admin
SPRING_SECURITY_USER_PASSWORD=change_me_too
